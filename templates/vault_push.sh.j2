#!/usr/bin/env bash
set -o errexit
set -o pipefail
set -o nounset

# -------------
# Konfiguration logging
# -------------

SERVICE_NAME="vault_push"
ENVIRONMENT="${ENVIRONMENT:-dev}"
LOG_FILE="/var/log/${SERVICE_NAME}.log"
RUN_ID="$(date -u +%Y%m%dT%H%M%SZ)-$$"

log() {
    local level="$1"
    shift
    local message="$*"

    printf '{"ts":"%s","level":"%s","service":"%s","env":"%s","run_id":"%s","msg":"%s"}\n' \
        "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
        "$level" \
        "$SERVICE_NAME" \
        "$ENVIRONMENT" \
        "$RUN_ID" \
        "$(echo "$message" | sed 's/"/\\"/g')" \
        >> "$LOG_FILE"
}

log_info()  { log INFO "$@"; }
log_warn()  { log WARN "$@"; }
log_error() { log ERROR "$@"; }

trap 'log_error "Script failed (exit=$?)"' ERR

VAULT_ADDR="{{ acme_vault_addr }}"
VAULT_PATH="{{ acme_vault_path }}/$Le_Domain"
ROLE_ID_FILE="{{ acme_vault_approle_role_id_file }}"
SECRET_ID_FILE="{{ acme_vault_approle_secret_id_file }}"

export VAULT_ADDR

ROLE_ID=$(cat "$ROLE_ID_FILE")
SECRET_ID=$(cat "$SECRET_ID_FILE")

if ! VAULT_TOKEN=$(vault write -field=token auth/approle/login \
    role_id="$ROLE_ID" \
    secret_id="$SECRET_ID" 2>/dev/null); then

    log_error "Vault Login fehlgeschlagen (vault command error)"
    exit 1
fi

if [[ -z "${VAULT_TOKEN:-}" ]]; then
    log_error "Vault Login fehlgeschlagen (Token leer)"
    exit 1
fi

export VAULT_TOKEN

log_info "Erfolgreich bei Vault eingeloggt"

if [[ ! -s "${CERT_FULLCHAIN_PATH:-}" ]]; then
    log_error "Fullchain ist leer"
    exit 1
fi

CERT_FULLCHAIN=$(<"$CERT_FULLCHAIN_PATH")

if [[ ! -s "${CERT_KEY_PATH:-}" ]]; then
    log_error "Private key ist leer"
    exit 1
fi

CERT_KEY=$(<"$CERT_KEY_PATH")

if ! vault kv put "$VAULT_PATH" pem="$CERT_FULLCHAIN" key="$CERT_KEY" >/dev/null 2>&1; then
    log_error "Vault KV put fehlgeschlagen"
    exit 1
fi

log_info "Certs erfolgreich hochgeladen"
