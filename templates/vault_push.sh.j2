#!/usr/bin/env bash
set -euo pipefail

VAULT_ADDR="{{ acme_vault_addr }}"
VAULT_PATH="secret/certs/$Le_Domain"
ROLE_ID_FILE="/etc/vault/role_id"
SECRET_ID_FILE="/etc/vault/secret_id"

export VAULT_ADDR

ROLE_ID=$(cat "$ROLE_ID_FILE")
SECRET_ID=$(cat "$SECRET_ID_FILE")

VAULT_TOKEN=$(vault write -field=token auth/approle/login \
  role_id="$ROLE_ID" \
  secret_id="$SECRET_ID")
export VAULT_TOKEN

CERT_FULLCHAIN=$(cat "$CERT_FULLCHAIN_PATH";)
CERT_KEY=$(cat "$CERT_KEY_PATH";)

vault kv put "$VAULT_PATH" pem="$CERT_FULLCHAIN" key="$CERT_KEY"
